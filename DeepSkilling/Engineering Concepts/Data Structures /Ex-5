using System;

class TaskNode
{
    public int TaskId;
    public string TaskName;
    public string Status;
    public TaskNode Next;

    public TaskNode(int id, string name, string status)
    {
        TaskId = id;
        TaskName = name;
        Status = status;
        Next = null;
    }
}

class TaskList
{
    TaskNode head = null;

    public void AddTask(int id, string name, string status)
    {
        TaskNode newNode = new TaskNode(id, name, status);

        if (head == null)
        {
            head = newNode;
            return;
        }

        TaskNode temp = head;
        while (temp.Next != null)
            temp = temp.Next;

        temp.Next = newNode;
    }

    public void Display()
    {
        TaskNode temp = head;

        while (temp != null)
        {
            Console.WriteLine(temp.TaskName + " - " + temp.Status);
            temp = temp.Next;
        }
    }
}

class Program
{
    static void Main()
    {
        TaskList tasks = new TaskList();

        tasks.AddTask(1, "Coding", "Pending");
        tasks.AddTask(2, "Testing", "Completed");

        tasks.Display();
    }
}
