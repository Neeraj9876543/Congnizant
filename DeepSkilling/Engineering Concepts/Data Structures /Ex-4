using System;

class Employee
{
    public int EmployeeId;
    public string Name;
    public string Position;
    public double Salary;

    public Employee(int id, string name, string position, double salary)
    {
        EmployeeId = id;
        Name = name;
        Position = position;
        Salary = salary;
    }
}

class Program
{
    static Employee[] employees = new Employee[10];
    static int count = 0;

    static void AddEmployee(Employee e)
    {
        employees[count++] = e;
    }

    static void SearchEmployee(int id)
    {
        for (int i = 0; i < count; i++)
        {
            if (employees[i].EmployeeId == id)
            {
                Console.WriteLine("Found: " + employees[i].Name);
                return;
            }
        }
        Console.WriteLine("Not Found");
    }

    static void DisplayEmployees()
    {
        for (int i = 0; i < count; i++)
        {
            Console.WriteLine(employees[i].Name + " - " + employees[i].Position);
        }
    }

    static void DeleteEmployee(int id)
    {
        for (int i = 0; i < count; i++)
        {
            if (employees[i].EmployeeId == id)
            {
                for (int j = i; j < count - 1; j++)
                {
                    employees[j] = employees[j + 1];
                }
                count--;
                break;
            }
        }
    }

    static void Main()
    {
        AddEmployee(new Employee(1, "Ravi", "Manager", 50000));
        AddEmployee(new Employee(2, "Kiran", "Developer", 40000));

        DisplayEmployees();

        SearchEmployee(2);

        DeleteEmployee(1);

        Console.WriteLine("After Deletion:");
        DisplayEmployees();
    }
}
