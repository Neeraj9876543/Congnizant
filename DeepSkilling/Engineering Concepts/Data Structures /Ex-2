using System;

class Product
{
    public int ProductId;
    public string ProductName;
    public string Category;

    public Product(int id, string name, string category)
    {
        ProductId = id;
        ProductName = name;
        Category = category;
    }
}

class Program
{
    static int LinearSearch(Product[] products, string key)
    {
        for (int i = 0; i < products.Length; i++)
        {
            if (products[i].ProductName == key)
                return i;
        }
        return -1;
    }

    static int BinarySearch(Product[] products, string key)
    {
        int low = 0;
        int high = products.Length - 1;

        while (low <= high)
        {
            int mid = (low + high) / 2;
            int result = String.Compare(products[mid].ProductName, key);

            if (result == 0)
                return mid;
            else if (result < 0)
                low = mid + 1;
            else
                high = mid - 1;
        }

        return -1;
    }

    static void Main(string[] args)
    {
        Product[] products =
        {
            new Product(1, "Apple", "Fruit"),
            new Product(2, "Banana", "Fruit"),
            new Product(3, "Laptop", "Electronics")
        };

        int index1 = LinearSearch(products, "Laptop");
        Console.WriteLine("Linear Search Result: " + index1);

        int index2 = BinarySearch(products, "Laptop");
        Console.WriteLine("Binary Search Result: " + index2);
    }
}
