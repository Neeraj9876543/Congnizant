/* =====================================================
   EXERCISE 1
   RANKING & WINDOW FUNCTIONS
   ===================================================== */

PRINT 'EXERCISE 1 - ROW_NUMBER, RANK, DENSE_RANK';

SELECT
    ProductID,
    ProductName,
    Category,
    Price,

    ROW_NUMBER() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS RowNum,

    RANK() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS RankNum,

    DENSE_RANK() OVER
    (
        PARTITION BY Category
        ORDER BY Price DESC
    ) AS DenseRankNum

FROM Products;

GO

PRINT 'TOP 3 PRODUCTS IN EACH CATEGORY';

WITH RankedProducts AS
(
    SELECT *,
           ROW_NUMBER() OVER
           (
               PARTITION BY Category
               ORDER BY Price DESC
           ) AS rn
    FROM Products
)

SELECT *
FROM RankedProducts
WHERE rn <= 3;

GO

/* =====================================================
   EXERCISE 2
   GROUPING SETS
   ===================================================== */

PRINT 'EXERCISE 2 - GROUPING SETS';

SELECT
    c.Region,
    p.Category,
    SUM(od.Quantity) AS TotalQuantity
FROM Orders o
JOIN Customers c
ON o.CustomerID = c.CustomerID
JOIN OrderDetails od
ON o.OrderID = od.OrderID
JOIN Products p
ON od.ProductID = p.ProductID
GROUP BY GROUPING SETS
(
    (c.Region),
    (p.Category),
    (c.Region, p.Category)
);

GO

/* =====================================================
   ROLLUP
   ===================================================== */

PRINT 'ROLLUP';

SELECT
    c.Region,
    p.Category,
    SUM(od.Quantity) AS TotalQuantity
FROM Orders o
JOIN Customers c
ON o.CustomerID = c.CustomerID
JOIN OrderDetails od
ON o.OrderID = od.OrderID
JOIN Products p
ON od.ProductID = p.ProductID
GROUP BY ROLLUP(c.Region,p.Category);

GO

/* =====================================================
   CUBE
   ===================================================== */

PRINT 'CUBE';

SELECT
    c.Region,
    p.Category,
    SUM(od.Quantity) AS TotalQuantity
FROM Orders o
JOIN Customers c
ON o.CustomerID = c.CustomerID
JOIN OrderDetails od
ON o.OrderID = od.OrderID
JOIN Products p
ON od.ProductID = p.ProductID
GROUP BY CUBE(c.Region,p.Category);

GO

