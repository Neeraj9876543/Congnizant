/* =====================================================
   EXERCISE 4
   PIVOT
   ===================================================== */

PRINT 'EXERCISE 4 - PIVOT';

SELECT *
FROM
(
    SELECT
        p.ProductName,
        MONTH(o.OrderDate) AS SalesMonth,
        od.Quantity
    FROM Orders o
    JOIN OrderDetails od
        ON o.OrderID = od.OrderID
    JOIN Products p
        ON od.ProductID = p.ProductID
) AS SourceData

PIVOT
(
    SUM(Quantity)
    FOR SalesMonth IN
    (
        [1],[2],[3]
    )
) AS PivotTable;

GO

/* =====================================================
   UNPIVOT
   ===================================================== */

PRINT 'UNPIVOT';

WITH PivotData AS
(
    SELECT *
    FROM
    (
        SELECT
            p.ProductName,
            MONTH(o.OrderDate) AS SalesMonth,
            od.Quantity
        FROM Orders o
        JOIN OrderDetails od
            ON o.OrderID = od.OrderID
        JOIN Products p
            ON od.ProductID = p.ProductID
    ) AS SourceData

    PIVOT
    (
        SUM(Quantity)
        FOR SalesMonth IN ([1],[2],[3])
    ) AS P
)

SELECT *
FROM PivotData

UNPIVOT
(
    Quantity
    FOR SalesMonth IN ([1],[2],[3])
) AS U;

GO

/* =====================================================
   EXERCISE 5
   CTE - CUSTOMERS WITH MORE THAN 3 ORDERS
   ===================================================== */

PRINT 'EXERCISE 5 - CUSTOMER ORDER COUNTS';

WITH CustomerOrderCounts AS
(
    SELECT
        CustomerID,
        COUNT(OrderID) AS OrderCount
    FROM Orders
    GROUP BY CustomerID
)

SELECT
    c.CustomerID,
    c.Name,
    coc.OrderCount
FROM CustomerOrderCounts coc
JOIN Customers c
ON c.CustomerID = coc.CustomerID
WHERE coc.OrderCount > 3;

